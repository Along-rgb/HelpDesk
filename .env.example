# ============================================
# HelpDesk Frontend — ตัวอย่าง Environment
# คัดลอกเป็น .env.local แล้วเติมค่าจริง
# ============================================

# ----- URL ฐานของแอป (ใช้ใน metadata / Open Graph / แชร์ลิงก์) -----
# NEXT_PUBLIC_APP_URL=http://localhost:3500
# ເວັ້ນແຕ່ວ່າຕັ້ງຄ່າ Next.js ຈະໃຊ້ http://localhost:3500 (ຫຼື port ທີ່ຮັນ)

# ----- HelpDesk API หลัก (users, buildings, floors, issues, support team, service requests) -----
NEXT_PUBLIC_HELPDESK_API_BASE_URL=http://192.168.20.163:4000/api
# Path login (default: auth/login) — ຖ້າ backend ໃຊ້ userName ແທນ username ໃຫ້ຕັ້ງ NEXT_PUBLIC_LOGIN_USE_PASCAL_CASE=true
# NEXT_PUBLIC_HELPDESK_AUTH_LOGIN_PATH=auth/login
# NEXT_PUBLIC_LOGIN_USE_PASCAL_CASE=false

# ----- Tickets API (ถ้าแยก service กัน) -----
NEXT_PUBLIC_TICKETS_API_URL=http://localhost:3501

# ----- Reports API -----
NEXT_PUBLIC_REPORTS_API_URL=http://localhost:3000/api

# ----- Change Password API (เปลี่ยนรหัสผ่าน; ว่างหรือ # = ยังไม่เชื่อม) -----
NEXT_PUBLIC_CHANGE_PASSWORD_API_URL=

# ----- หมายเหตุ -----
# - NEXT_PUBLIC_* เท่านั้นที่ frontend อ่านได้
# - หลังแก้ .env.local ต้อง restart dev server (npm run dev)
