# ============================================
# HelpDesk Frontend — Environment Template
# คัดลอกเป็น .env.local แล้วเติมค่าจริง (ห้าม commit ไฟล์ .env หรือ .env.local)
# ============================================
# Next.js: ตัวแปรที่ใช้ฝั่ง Client ต้องขึ้นต้นด้วย NEXT_PUBLIC_
# หลังแก้ .env.local ต้อง restart dev server (npm run dev)

# ----- App / Metadata -----
NEXT_PUBLIC_APP_URL=
# ตัวอย่าง (dev): http://localhost:3500 (แอปรันที่ port 3500)
# ใช้เป็น metadataBase, Open Graph url

NEXT_PUBLIC_OG_IMAGE_URL=
# รูป Open Graph (optional) — URL เต็มหรือ path เช่น /layout/images/faifarlao.png

# ----- Next.js Image (optional) -----
NEXT_PUBLIC_IMAGE_REMOTE_HOSTNAME=
# Hostname only for Next/Image remotePatterns (e.g. for category icons). Leave empty to disable.

# ----- HelpDesk API หลัก -----
NEXT_PUBLIC_HELPDESK_API_BASE_URL=
# ตัวอย่าง: https://adi-test.com.la/setbox/api
# ถ้า Backend ใช้แค่ /helpdesk (ไม่มี /api) ใส่ https://adi-test.com.la/setbox

NEXT_PUBLIC_HELPDESK_AUTH_LOGIN_PATH=auth/login
# Path สำหรับ login (default: auth/login)

NEXT_PUBLIC_HELPDESK_UPLOAD_BASE_URL=
# Base URL สำหรับรูป category icons บน Backend (path ตาม Backend: /upload/categoryicon ไม่มี s)
# ตัวอย่าง: https://adi-test.com.la/setbox/upload/categoryicon
# ถ้าว่าง จะ derive จาก NEXT_PUBLIC_HELPDESK_API_BASE_URL โดยต่อ /upload/categoryicon

NEXT_PUBLIC_LOGIN_USE_PASCAL_CASE=false
# ตั้ง true ถ้า Backend ใช้ userName (PascalCase) แทน username

NEXT_PUBLIC_USE_LOCAL_CATEGORY_ICON_UPLOAD=false
# ตั้ง true สำหรับ demo: อัปโหลดรูปไปที่ public/uploads/ และแสดงที่ /uploads/filename (ไม่ใช้ Backend)

NEXT_PUBLIC_USE_HELPDESK_PROXY=false
# ตั้ง true เมื่อเจอ CORS (localhost:3500 → api-test.edl.com.la): ยิงผ่าน proxy /api/proxy-helpdesk แทนตรงไป API

# ชื่อ field ใน FormData ตอนส่งคำขอ (ว่าง = ใช้ค่า default)
# NEXT_PUBLIC_HELPDESK_FIELD_FILE=hdFile
# NEXT_PUBLIC_HELPDESK_FIELD_IMAGES=hdImgs
# ถ้า Backend ใช้ชื่ออื่น เช่น hdfile, hdimgs ให้ตั้งตรงนี้

# ----- Tickets API (ถ้าแยก service) -----
NEXT_PUBLIC_TICKETS_API_URL=
# ตัวอย่าง (dev): http://localhost:3501

# ----- Reports API -----
NEXT_PUBLIC_REPORTS_API_URL=
# ตัวอย่าง: http://localhost:3000/api

# ----- Change Password API -----
NEXT_PUBLIC_CHANGE_PASSWORD_API_URL=
# URL สำหรับเปลี่ยนรหัสผ่าน (ว่าง = ยังไม่เชื่อม)
